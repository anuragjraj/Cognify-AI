generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String       @id @default(uuid())
  email                String       @unique
  name                 String
  passwordHash         String?      @map("password_hash")
  googleId             String?      @unique @map("google_id")
  avatarUrl            String?      @map("avatar_url")
  plan                 String       @default("free") // free | pro
  planExpiresAt        DateTime?    @map("plan_expires_at")
  stripeCustomerId     String?      @map("stripe_customer_id")
  stripeSubscriptionId String?      @map("stripe_subscription_id")
  createdAt            DateTime     @default(now()) @map("created_at")
  courses              Course[]
  videos               SavedVideo[]

  @@map("users")
}

model Course {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  topic       String
  status      String    @default("generating") // generating | in-progress | completed | error
  finalScore  Int?      @map("final_score")
  finalGrade  String?   @map("final_grade")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  modules     Module[]

  @@index([userId])
  @@map("courses")
}

model Module {
  id               String   @id @default(uuid())
  courseId         String   @map("course_id")
  title            String
  description      String
  emoji            String   @default("📚")
  order            Int
  searchQuery      String?  @map("search_query")
  genStatus        String   @default("pending") @map("gen_status") // pending | building | done | error
  videoId          String?  @map("video_id")
  searchResults    Json?    @map("search_results")
  transcript       String?
  transcriptStatus String?  @default("none") @map("transcript_status") // none | pending | success | unavailable
  notes            Json?
  qa               Json?
  quizQuestions    Json?    @map("quiz_questions")
  quizCompleted    Boolean  @default(false) @map("quiz_completed")
  quizScore        Int?     @map("quiz_score")
  aiModel          String?  @map("ai_model") // track which model generated it
  createdAt        DateTime @default(now()) @map("created_at")
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("modules")
}

model SavedVideo {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  videoId          String   @map("video_id")
  title            String
  searchQuery      String?  @map("search_query")
  transcript       String?
  transcriptStatus String?  @default("none") @map("transcript_status")
  notes            Json?
  qa               Json?
  quizQuestions    Json?    @map("quiz_questions")
  quizCompleted    Boolean  @default(false) @map("quiz_completed")
  quizScore        Int?     @map("quiz_score")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_videos")
}

model Cache {
  key       String   @id
  value     Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("cache")
}
